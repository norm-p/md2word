# Pandoc binary — set this if pandoc is NOT on your PATH.
# Download from https://github.com/jgm/pandoc/releases and place in tools/.
# Leave blank or remove this line if pandoc is installed system-wide.
PYPANDOC_PANDOC=tools/pandoc.exe

# AI provider (optional — tool works without it in deterministic-only mode)
# Select: anthropic | azure | bedrock | vertex | openai | azure-openai
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# Anthropic direct
ANTHROPIC_API_KEY=

# Azure AI Foundry (Anthropic endpoint)
AZURE_ANTHROPIC_KEY=
AZURE_ANTHROPIC_ENDPOINT=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Google Vertex AI
VERTEX_PROJECT_ID=
VERTEX_REGION=

# OpenAI direct
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
